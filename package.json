{
  "name": "@prorobotech/openapi-k8s-toolkit",
  "version": "1.4.0-alpha.16",
  "description": "ProRobotech OpenAPI k8s tools",
  "main": "dist/openapi-k8s-toolkit.cjs.js",
  "module": "dist/openapi-k8s-toolkit.es.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PRO-Robotech/openapi-k8s-toolkit.git"
  },
  "scripts": {
    "dev": "concurrently \"npm run watch:build\" \"npm run watch:yalc\"",
    "watch:build": "chokidar \"src/**/*\" -c \"npm run build\" -d 5000",
    "watch:yalc": "chokidar \"dist/**/*\" -c \"yalc push\" -d 5000",
    "dev:open": "cross-env BASEPREFIX=/toolkit vite --open --port 3002 --strictPort",
    "build": "vite build && tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "build:local": "vite build && tsc -p tsconfig.json && tsc-alias -p tsconfig.json && yalc publish --replace && yalc push",
    "serve": "vite preview --port 3002 --strictPort",
    "preview": "vite preview --port 3002 --strictPort",
    "tsc": "tsc --project tsconfig.json",
    "lint:css": "stylelint ./src/**/styled.{js,ts} --fix",
    "lint:js": "eslint .",
    "lint": "npm run lint:js && npm run lint:css && npm run tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:serve": "serve storybook-static"
  },
  "peerDependencies": {
    "@ant-design/icons": "5.6.0",
    "@tanstack/react-query": "5.62.2",
    "@tanstack/react-query-devtools": "5.62.2",
    "antd": "5.26.4",
    "novnc-next": "1.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^6.25.1"
  },
  "dependencies": {
    "@monaco-editor/react": "4.6.0",
    "@reduxjs/toolkit": "2.2.5",
    "@xterm/addon-attach": "0.11.0",
    "@xterm/addon-fit": "0.10.0",
    "@xterm/xterm": "5.5.0",
    "axios": "1.12.2",
    "cross-env": "7.0.3",
    "dotenv": "16.4.7",
    "jsonpath": "1.1.1",
    "lodash": "4.17.21",
    "openapi-types": "12.1.3",
    "react-redux": "9.1.2",
    "recharts": "3.5.1",
    "spoiled": "0.4.0",
    "styled-components": "6.0.7",
    "typescript": "4.9.5",
    "usehooks-ts": "3.1.1",
    "uuid": "11.0.3",
    "xterm-theme": "1.1.0",
    "yaml": "2.7.0"
  },
  "devDependencies": {
    "@ant-design/icons": "5.6.0",
    "@storybook/react-vite": "9.1.2",
    "@stylelint/postcss-css-in-js": "0.38.0",
    "@tanstack/react-query": "5.62.2",
    "@tanstack/react-query-devtools": "5.62.2",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@types/jest": "30.0.0",
    "@types/jsonpath": "0.2.4",
    "@types/lodash": "4.17.13",
    "@types/node": "20.5.4",
    "@types/react": "18.2.25",
    "@types/react-dom": "18.2.7",
    "@types/react-router-dom": "5.3.3",
    "@types/styled-components": "5.1.26",
    "@typescript-eslint/eslint-plugin": "8.6.0",
    "@vitejs/plugin-react-swc": "3.7.0",
    "antd": "5.26.4",
    "chokidar-cli": "3.0.0",
    "concurrently": "9.2.0",
    "eslint": "8.57.1",
    "eslint-config-airbnb": "19.0.4",
    "eslint-config-prettier": "9.0.0",
    "eslint-plugin-import": "2.28.1",
    "eslint-plugin-jsx-a11y": "6.7.1",
    "eslint-plugin-prettier": "5.0.0",
    "eslint-plugin-react": "7.33.2",
    "eslint-plugin-react-hooks": "4.6.0",
    "jest": "30.2.0",
    "jest-environment-jsdom": "30.2.0",
    "jest-styled-components": "^7.2.0",
    "msw": "2.12.4",
    "msw-storybook-addon": "2.0.6",
    "postcss": "8.5.2",
    "postcss-styled-syntax": "0.7.1",
    "prettier": "3.0.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.25.1",
    "serve": "14.2.4",
    "storybook": "9.1.2",
    "stylelint": "16.14.1",
    "stylelint-config-standard": "37.0.0",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "tsc-alias": "1.8.16",
    "vite": "5.4.6",
    "vite-plugin-node-polyfills": "0.22.0",
    "vite-tsconfig-paths": "5.0.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
